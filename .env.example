# Copy to .env and fill in real values. Never commit .env.

# Password for the TimescaleDB "postgres" user (docker-compose db service).
# The compose file falls back to "secret" if unset — override for anything beyond local dev.
DB_PASSWORD=changeme

# Full connection string used by the ingestor (set automatically by docker-compose;
# only needed here when running the ingestor outside Docker against the mapped port).
# DATABASE_URL=postgresql://postgres:changeme@localhost:5433/energy

# Claude API key used by the M3 crawler service for claim extraction
# (shared/claim_extractor.py) and, since M4, the orchestrator's Event Report
# synthesis (shared/event_synthesizer.py, Claude Opus). If unset, both skip
# gracefully -- the crawler stores raw article text without derived claims,
# and the orchestrator skips synthesis (the raw trigger still reaches Slack
# via shared/rule_engine.py) -- instead of crashing.
# ANTHROPIC_API_KEY=

# Slack webhook used by the M2 rule engine (raw triggers) and M4 orchestrator
# (synthesized Event Reports) -- shared/slack_notifier.py. If unset, both
# just log a warning and skip the Slack post instead of crashing.
# SLACK_WEBHOOK_URL=

# Optional API key for the Phase 5 API (services/api/main.py). If unset, the
# JSON API (/series*, /event-reports*, /triggers) stays fully open, exactly
# as before -- set this before exposing the API beyond local dev. Callers
# then send it as the `X-API-Key` header. /health and /metrics are always
# unauthenticated (healthchecks/Prometheus scraping). See DEPLOYMENT.md.
# API_KEY=

# Cost-control gate on the crawler's and orchestrator's *automatic* scheduled
# cycles (services/crawler/main.py, services/orchestrator/main.py). Defaults
# to "false" (unset = off) -- automatic scheduled cycles are opt-in, not
# opt-out:
#   - orchestrator (15-min interval): each fired rule-engine trigger costs
#     one Claude Opus call (shared/event_synthesizer.py) -- Opus is the most
#     expensive model this repo calls, and in live runs 2-7 triggers have
#     fired per 15-minute cycle.
#   - crawler (30-min interval): each new RSS article costs one Claude Haiku
#     call (shared/claim_extractor.py) -- cheaper per-call than Opus, but
#     still adds up across every new article on every feed, every cycle.
#   - ingestor has NO such gate and always runs unconditionally -- it makes
#     zero LLM calls (pure Energinet HTTP polling + Postgres writes), so
#     there's no spend to control there.
# Set AUTO_RUN_ENABLED=true to restore fully-automatic scheduled cycles for
# both services. Regardless of this setting, you can always fire one real
# cycle on demand: POST /orchestrator/run-now or POST /crawler/run-now on the
# API service (gated by API_KEY like other mutating routes, see below), or
# the matching "Run now" buttons on the dashboard homepage (/). See
# DEPLOYMENT.md.
# AUTO_RUN_ENABLED=false

# Grafana admin password (docker-compose.yml grafana service). Defaults to
# "admin" for local dev -- override for anything beyond local dev.
# GRAFANA_ADMIN_PASSWORD=

# --- Reserved for upcoming phases (not read by any code yet) ---
# ENTSOE_API_TOKEN=
