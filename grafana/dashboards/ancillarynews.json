{
  "title": "AncillaryNews -- Service Health",
  "uid": "ancillarynews-health",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "utc",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Ingestion success rate (per dataset poll)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(ingestor_dataset_poll_total{status=\"success\"}[15m])) / sum(rate(ingestor_dataset_poll_total[15m]))",
          "legendFormat": "success ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    },
    {
      "id": 2,
      "title": "Trigger fired rate, by type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (trigger_type) (rate(rule_engine_trigger_fired_total[15m]))",
          "legendFormat": "{{trigger_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 3,
      "title": "Orchestrator LLM synthesis call latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(orchestrator_llm_call_duration_seconds_bucket[15m])) by (le))",
          "legendFormat": "p95 latency (s)",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 4,
      "title": "Event Report citation rejections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(orchestrator_citation_rejected_total[1h])",
          "legendFormat": "rejections/s",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 5,
      "title": "Crawl cycle duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(crawler_cycle_duration_seconds_bucket[30m])) by (le))",
          "legendFormat": "p95 duration (s)",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 6,
      "title": "API request rate, by status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (status) (rate(api_requests_total[15m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 7,
      "title": "Series with zero new rows in the last 6h (typo / silently-null detector)",
      "description": "shared/dataset_validation.py's Stage 2 guardrail. A series that flatlines at 0 for 6h straight is either a typo'd `value_field` in shared/datasets.py (never ingests, ever) or a column that's genuinely gone quiet -- either way, worth a look. See services/ingestor/main.py's SERIES_ROWS_TOTAL comment.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "increase(ingestor_series_rows_total[6h]) == 0",
          "legendFormat": "{{dataset}}/{{market}}/{{product}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ]
}
